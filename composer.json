        "spiral/roadrunner-http": "^3.5",
        "nyholm/psr7": "^1.8",
        "symfony/routing": "^7.2",
        "symfony/http-foundation": "^7.2",
        "symfony/uid": "^7.2",
        "doctrine/orm": "^3.3",
        "doctrine/dbal": "^4.2",
