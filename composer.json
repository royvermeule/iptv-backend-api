{
    "name": "iptv/backend-api",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "doctrine/dbal": "^4.2",
        "doctrine/orm": "^3.3",
        "firebase/php-jwt": "^6.10",
        "nyholm/psr7": "^1.8",
        "predis/predis": "^2.3",
        "spiral/roadrunner-cli": "^2.0",
        "spiral/roadrunner-http": "^3.5",
        "symfony/cache": "^7.2",
        "symfony/http-foundation": "^7.2",
        "symfony/routing": "^7.2",
        "symfony/uid": "^7.2",
        "symfony/var-exporter": "^7.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },

    "scripts": {
        "post-install-cmd": ["@php vendor/bin/rr get-binary"],
        "post-update-cmd": ["@php vendor/bin/rr get-binary"],
        "start": "@php bin/serve.php",
        "schema:create": "@php bin/schema-create.php",
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    }
}
