meta {
  name: Get Xtream Credentials
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/credentials
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{accessToken}}
}

vars:pre-request {
  accessToken: eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJzdWIiOiI3N2IyOTk2MC01NDRjLTQxNTUtYTg3MC01NzhkZmFkMjQ2NTQiLCJwcm9maWxlX2lkIjoiMDlmYTlkYTQtNTRmNC00MmY2LWI1NTItNzBlOGRhNmVhOTY0IiwiaWF0IjoxNzc4MjUwMjUxLCJleHAiOjE3NzgyNTExNTF9.vjjYA7SuujRaeQz9rkZfTDZETiUCbODnom4TxmpjgNM"
}

tests {
  test("returns 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("has url", function() {
    expect(res.body.url).to.be.a("string");
  });
  
  test("has username", function() {
    expect(res.body.username).to.be.a("string");
  });
  
  test("has password", function() {
    expect(res.body.password).to.be.a("string");
  });
}
