meta {
  name: Store Credentials - Validation Error
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/profiles/{{profileId}}/credentials
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "xtream_url": "",
    "xtream_username": "",
    "xtream_password": ""
  }
}

tests {
  test("returns 422", function() {
    expect(res.status).to.equal(422);
  });

  test("has error message", function() {
    expect(res.body.error).to.be.a("string");
  });
}
